{
  "name": "PhyloGen Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "settings": {
    "terminal.integrated.shell.linux": "/bin/bash"
  },
  "forwardPorts": [8501],
  "postCreateCommand": "pip install -r requirements.txt",
  "extensions": [
    "ms-python.python",
    "ms-toolsai.jupyter"
  ],
  "features": {},
  "remoteUser": "root"
}
